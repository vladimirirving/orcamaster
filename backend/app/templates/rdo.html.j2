{# backend/app/templates/rdo.html.j2 #}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<style>
  @page { size: A4; margin: 2cm; }
  body { font-family: Liberation Sans, Arial, sans-serif; font-size: 10pt; color: #111; }
  h1 { font-size: 13pt; margin: 0 0 2pt; }
  h2 { font-size: 11pt; margin: 14pt 0 4pt; border-bottom: 1px solid #ccc; padding-bottom: 2pt; }
  .header { text-align: center; margin-bottom: 16pt; }
  .header .sub { font-size: 9pt; color: #555; }
  .meta { display: flex; gap: 40pt; margin-bottom: 10pt; }
  .meta div { flex: 1; }
  .label { font-size: 8pt; color: #777; text-transform: uppercase; letter-spacing: 0.5pt; }
  .value { font-size: 10pt; }
  .section-text { white-space: pre-wrap; font-size: 9.5pt; color: #222;
                  border: 0.5pt solid #ddd; padding: 6pt 8pt; margin-bottom: 8pt; }
  .fotos-grid { display: flex; flex-wrap: wrap; gap: 8pt; margin-top: 8pt; }
  .foto-item { width: 240pt; text-align: center; }
  .foto-item img { width: 240pt; height: 160pt; object-fit: cover; border: 0.5pt solid #ccc; }
  .foto-nome { font-size: 7.5pt; color: #666; margin-top: 2pt; }
  .footer { margin-top: 30pt; border-top: 0.5pt dotted #888;
            padding-top: 8pt; font-size: 9pt; text-align: center; color: #555; }
</style>
</head>
<body>

<div class="header">
  <h1>{{ empresa.nome }}</h1>
  <div class="sub">CNPJ: {{ empresa.cnpj }}</div>
  <div class="sub" style="margin-top:4pt;font-weight:bold;">RELATÓRIO DIÁRIO DE OBRAS (RDO)</div>
</div>

<div class="meta">
  <div>
    <div class="label">Obra</div>
    <div class="value">{{ obra.nome }}</div>
  </div>
  <div>
    <div class="label">Data</div>
    <div class="value">{{ entrada.data.strftime('%d/%m/%Y') }}</div>
  </div>
</div>

<h2>Condições Climáticas e Turnos</h2>
<div class="meta">
  <div>
    <div class="label">Clima</div>
    <div class="value">{{ clima_label }}</div>
  </div>
  <div>
    <div class="label">Turnos Trabalhados</div>
    <div class="value">{{ turnos_label or '—' }}</div>
  </div>
</div>

<h2>Equipe</h2>
<div class="meta">
  <div>
    <div class="label">Efetivo</div>
    <div class="value">{{ entrada.efetivo }} trabalhador{{ 'es' if entrada.efetivo != 1 else '' }}</div>
  </div>
</div>
{% if entrada.equipes %}
<div class="section-text">{{ entrada.equipes }}</div>
{% endif %}

{% if entrada.equipamentos %}
<h2>Equipamentos</h2>
<div class="section-text">{{ entrada.equipamentos }}</div>
{% endif %}

<h2>Atividades Executadas</h2>
<div class="section-text">{{ entrada.atividades }}</div>

{% if entrada.ocorrencias %}
<h2>Ocorrências</h2>
<div class="section-text">{{ entrada.ocorrencias }}</div>
{% endif %}

{% if fotos %}
<h2>Registro Fotográfico</h2>
<div class="fotos-grid">
  {% for foto in fotos %}
  <div class="foto-item">
    <img src="file://{{ foto.path_abs | safe }}" alt="{{ foto.nome_original }}" />
    <div class="foto-nome">{{ foto.nome_original }}</div>
  </div>
  {% endfor %}
</div>
{% endif %}

<div class="footer">
  Responsável Técnico: {{ responsavel }}<br>
  Gerado em: {{ gerado_em }}
</div>

</body>
</html>
